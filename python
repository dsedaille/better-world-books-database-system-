# Report 4 - Customer Spending Summary
    def customer_spending_summary():
        print("\nCustomer Spending Summary:\n")

        query = """
        WITH CustomerSpending AS (
            SELECT 
                c.CustomerID,
                c.FirstName,
                c.LastName,
                COUNT(co.CustomerOrderID) AS OrderCount,
                COALESCE(SUM(co.TotalAmount), 0) AS TotalSpent
            FROM Customer c
            LEFT JOIN CustomerOrder co
                ON c.CustomerID = co.CustomerID
            GROUP BY c.CustomerID, c.FirstName, c.LastName
        )
        SELECT CustomerID, FirstName, LastName, OrderCount, TotalSpent
        FROM CustomerSpending
        ORDER BY TotalSpent DESC, CustomerID;
        """

        try:
            cursor.execute(query)
            results = cursor.fetchall()

            if results:
                for row in results:
                    print(
                        f"CustomerID: {row[0]}, "
                        f"Name: {row[1]} {row[2]}, "
                        f"Orders: {row[3]}, "
                        f"Total Spent: ${row[4]:.2f}"
                    )
            else:
                print("No customer spending data found.")

        except mysql.connector.Error as e:
            print("Error running Customer Spending Summary report:", e)
# Report 5 - Sales by Category (ROLLUP)
    def sales_by_category_rollup():
        print("\nSales by Category (ROLLUP):\n")

        query = """
        SELECT 
            c.CategoryName,
            SUM(oi.Quantity * oi.UnitPrice) AS TotalSales
        FROM OrderItem oi
        JOIN Book b ON oi.BookID = b.BookID
        JOIN Category c ON b.CategoryID = c.CategoryID
        GROUP BY c.CategoryName WITH ROLLUP;
        """

        try:
            cursor.execute(query)
            results = cursor.fetchall()

            if results:
                for row in results:
                    category = row[0] if row[0] is not None else "TOTAL"
                    total = row[1] if row[1] is not None else 0
                    print(f"Category: {category}, Sales: ${total:.2f}")
            else:
                print("No sales data found.")

        except mysql.connector.Error as e:
            print("Error running Sales by Category report:", e)

# Report 6 - Customers With Above Average Spending
    def customers_above_average_spending():
        print("\nCustomers Above Average Spending:\n")

        query = """
        WITH CustomerTotals AS (
            SELECT 
                c.CustomerID,
                c.FirstName,
                c.LastName,
                COALESCE(SUM(co.TotalAmount), 0) AS TotalSpent
            FROM Customer c
            LEFT JOIN CustomerOrder co
                ON c.CustomerID = co.CustomerID
            GROUP BY c.CustomerID, c.FirstName, c.LastName
        )
        SELECT *
        FROM CustomerTotals
        WHERE TotalSpent > (
            SELECT AVG(TotalSpent) FROM CustomerTotals
        )
        ORDER BY TotalSpent DESC;
        """

        try:
            cursor.execute(query)
            results = cursor.fetchall()

            if results:
                for row in results:
                    print(
                        f"CustomerID: {row[0]}, "
                        f"Name: {row[1]} {row[2]}, "
                        f"Total Spent: ${row[3]:.2f}"
                    )
            else:
                print("No customers above average spending.")

        except mysql.connector.Error as e:
            print("Error running Customers Above Average Spending report:", e)
